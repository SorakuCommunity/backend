{
  "version": 2,
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/src/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "ANIFY_URL": "https://api.anify.eltik.cc",
    "CONSUMET_URL": "https://api.consumet.org",
    "JIKAN_URL": "https://api.jikan.moe/v4",
    "HIANIME_URL": "https://api.hianime.to/api"
  }
}
